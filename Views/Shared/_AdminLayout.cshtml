<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="bg-light">

<div class="d-flex min-vh-100">
    <!-- SIDEBAR -->
    <nav class="admin-sidebar bg-dark text-white d-flex flex-column p-0" style="width:240px;min-height:100vh">
        <div class="p-3 border-bottom border-secondary">
            <a href="/admin" class="text-white text-decoration-none fw-bold fs-5">
                🛡️ Admin Panel
            </a>
        </div>
        <ul class="nav flex-column p-2 flex-grow-1">
            <li class="nav-item">
                <a href="/admin" class="nav-link text-white-50 @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active text-white" : "")">
                    <i class="bi bi-speedometer2 me-2"></i>Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a href="/admin/products" class="nav-link text-white-50 @(ViewContext.RouteData.Values["action"]?.ToString() == "Products" ? "active text-white" : "")">
                    <i class="bi bi-box-seam me-2"></i>Mahsulotlar
                </a>
            </li>
            <li class="nav-item">
                <a href="/admin/orders" class="nav-link text-white-50 @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active text-white" : "")">
                    <i class="bi bi-bag-check me-2"></i>Buyurtmalar
                </a>
            </li>
            <li class="nav-item">
                <a href="/admin/users" class="nav-link text-white-50 @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active text-white" : "")">
                    <i class="bi bi-people me-2"></i>Foydalanuvchilar
                </a>
            </li>
        </ul>
        <div class="p-3 border-top border-secondary">
            <a href="/" class="text-white-50 small text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Saytga qaytish</a>
        </div>
    </nav>

    <!-- MAIN -->
    <div class="flex-grow-1 d-flex flex-column">
        <!-- TOP BAR -->
        <div class="bg-white border-bottom px-4 py-2 d-flex align-items-center justify-content-between">
            <h6 class="mb-0 fw-semibold text-muted">@ViewData["Title"]</h6>
            <div class="text-muted small">
                <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name?.Split('@')[0]
                <form method="post" action="/Account/Logout" class="d-inline ms-3">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger py-0 px-2">Chiqish</button>
                </form>
            </div>
        </div>

        <!-- ALERTS -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-3 mb-0" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- CONTENT -->
        <div class="p-4 flex-grow-1">
            @RenderBody()
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
