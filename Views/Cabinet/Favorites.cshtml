@model List<Jahongir_diplomIshi.Models.Product>
@{
    ViewData["Title"] = "Sevimlilarim";
}

<div class="container py-5">
    <div class="row g-4">
        <div class="col-md-3">
            @await Html.PartialAsync("_CabinetSidebar")
        </div>
        <div class="col-md-9">
            <h5 class="fw-bold mb-4">Sevimli mahsulotlarim</h5>
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <div style="font-size:4rem">❤️</div>
                    <p class="mt-2">Sevimli mahsulotlar yo'q</p>
                    <a href="/" class="btn btn-success rounded-pill px-4 mt-2">Mahsulotlarni ko'rish</a>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var p in Model)
                    {
                        <div class="col-6 col-md-4">
                            @await Html.PartialAsync("_ProductCard", p)
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts { <script src="~/js/cart.js"></script> }
