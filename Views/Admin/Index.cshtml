@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- STATISTIKA KARTALAR -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 text-success rounded-3 p-3 fs-4">📦</div>
                <div>
                    <div class="text-muted small">Mahsulotlar</div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalProducts</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-warning bg-opacity-10 text-warning rounded-3 p-3 fs-4">🛒</div>
                <div>
                    <div class="text-muted small">Buyurtmalar</div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalOrders</div>
                    @if (ViewBag.PendingOrders > 0)
                    {
                        <span class="badge bg-warning text-dark small">@ViewBag.PendingOrders yangi</span>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-info bg-opacity-10 text-info rounded-3 p-3 fs-4">👥</div>
                <div>
                    <div class="text-muted small">Foydalanuvchilar</div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalUsers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 text-success rounded-3 p-3 fs-4">💰</div>
                <div>
                    <div class="text-muted small">Daromad</div>
                    <div class="fs-4 fw-bold text-success">@((decimal)ViewBag.TotalRevenue).ToString("N0") so'm</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SO'NGGI BUYURTMALAR -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold">So'nggi buyurtmalar</h6>
        <a href="/admin/orders" class="btn btn-sm btn-outline-success rounded-pill">Barchasi</a>
    </div>
    <div class="card-body p-0">
        @{
            var recentOrders = ViewBag.RecentOrders as List<Jahongir_diplomIshi.Models.Order> ?? new();
        }
        @if (!recentOrders.Any())
        {
            <p class="text-center text-muted py-4">Hali buyurtma yo'q</p>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4">Raqam</th>
                        <th>Mijoz</th>
                        <th>Tur</th>
                        <th>To'lov</th>
                        <th>Summa</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in recentOrders)
                    {
                        <tr>
                            <td class="px-4 fw-semibold">#@o.OrderNumber</td>
                            <td>@(o.User?.FullName ?? o.GuestName ?? "Mehmon")</td>
                            <td>@(o.OrderType == Jahongir_diplomIshi.Models.OrderType.Delivery ? "🚚 Yetkazish" : "🏪 Olib ketish")</td>
                            <td>
                                @if (o.PaymentStatus == Jahongir_diplomIshi.Models.PaymentStatus.Paid)
                                {
                                    <span class="badge bg-success-subtle text-success">✅ To'landi</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning">⏳ Kutilmoqda</span>
                                }
                            </td>
                            <td class="fw-bold text-success">@o.TotalAmount.ToString("N0") so'm</td>
                            <td>
                                @{
                                    var (cls, lbl) = o.Status switch {
                                        Jahongir_diplomIshi.Models.OrderStatus.Pending     => ("warning","Kutilmoqda"),
                                        Jahongir_diplomIshi.Models.OrderStatus.Processing  => ("primary","Tayyorlanmoqda"),
                                        Jahongir_diplomIshi.Models.OrderStatus.Ready       => ("info","Tayyor"),
                                        Jahongir_diplomIshi.Models.OrderStatus.Delivered   => ("success","Yetkazildi"),
                                        Jahongir_diplomIshi.Models.OrderStatus.Cancelled   => ("danger","Bekor"),
                                        _ => ("secondary","—")
                                    };
                                }
                                <span class="badge bg-@cls">@lbl</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
