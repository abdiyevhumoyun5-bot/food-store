@model List<Jahongir_diplomIshi.Models.User>
@{
    ViewData["Title"] = "Foydalanuvchilar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h5 class="fw-bold mb-0">Foydalanuvchilar (@ViewBag.Total)</h5>
</div>

<!-- QIDIRUV -->
<form method="get" action="/admin/users" class="mb-4">
    <div class="input-group" style="max-width:350px">
        <input type="text" name="search" class="form-control rounded-start-pill"
               placeholder="Ism yoki email..." value="@ViewBag.Search" />
        <button class="btn btn-outline-success rounded-end-pill" type="submit">
            <i class="bi bi-search"></i>
        </button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5 text-muted">
        <div style="font-size:4rem">👥</div>
        <p class="mt-2">Foydalanuvchi topilmadi</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3">Ism</th>
                        <th>Email</th>
                        <th>Telefon</th>
                        <th>Rol</th>
                        <th>Holat</th>
                        <th>Ro'yxat sanasi</th>
                        <th class="text-end px-4"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td class="px-4 py-3 fw-semibold">@u.FullName</td>
                            <td class="py-3 text-muted small">@u.Email</td>
                            <td class="py-3 text-muted small">@(u.Phone ?? "—")</td>
                            <td class="py-3">
                                <span class="badge @(u.Email?.Contains("admin") == true ? "bg-warning text-dark" : "bg-info-subtle text-info")">
                                    Foydalanuvchi
                                </span>
                            </td>
                            <td class="py-3">
                                @if (u.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Faol</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger">Bloklangan</span>
                                }
                            </td>
                            <td class="py-3 text-muted small">@u.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td class="py-3 text-end px-4">
                                <form method="post" action="/admin/ToggleUser" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <button class="btn btn-sm @(u.IsActive ? "btn-outline-danger" : "btn-outline-success") rounded-pill"
                                            title="@(u.IsActive ? "Bloklash" : "Faollashtirish")">
                                        <i class="bi @(u.IsActive ? "bi-person-x" : "bi-person-check")"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if ((int)(ViewBag.TotalPages ?? 1) > 1)
    {
        <nav class="mt-3 d-flex justify-content-center">
            <ul class="pagination pagination-sm">
                @for (int i = 1; i <= (int)(ViewBag.TotalPages ?? 1); i++)
                {
                    <li class="page-item @(i == (int)(ViewBag.CurrentPage ?? 1) ? "active" : "")">
                        <a class="page-link" href="?page=@i&search=@ViewBag.Search">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
