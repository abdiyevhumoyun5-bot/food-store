@model Jahongir_diplomIshi.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Kirish";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div style="font-size:3rem">🔐</div>
                        <h2 class="h4 fw-bold mt-2">Hisobga kirish</h2>
                        <p class="text-muted small">Foydalanuvchi paneli</p>
                    </div>

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label small fw-semibold">Email</label>
                            <input asp-for="Email" class="form-control rounded-pill" placeholder="email@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label small fw-semibold">Parol</label>
                            <input asp-for="Password" type="password" class="form-control rounded-pill" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label small">Meni eslab qol</label>
                        </div>

                        <button type="submit" class="btn btn-success w-100 rounded-pill py-2 fw-semibold">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Kirish
                        </button>
                    </form>

                    <div class="text-center mt-3 small text-muted">
                        Hisobingiz yo'qmi?
                        <a href="/Account/Register" class="text-success fw-semibold text-decoration-none">Ro'yxatdan o'tish</a>
                    </div>
                </div>
            </div>

            <!-- Admin kirish -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body p-3 text-center">
                    <p class="small text-muted mb-2">Admin panelga kirish uchun</p>
                    <a href="/Account/Login?admin=1" class="btn btn-outline-warning btn-sm rounded-pill px-4">
                        <i class="bi bi-shield-lock me-1"></i>Admin kirish
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
