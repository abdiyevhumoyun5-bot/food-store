@{
    ViewData["Title"] = "Buyurtma qabul qilindi";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div style="font-size:5rem" class="mb-3">✅</div>
            <h2 class="fw-bold text-success mb-3">Buyurtmangiz qabul qilindi!</h2>
            <p class="text-muted mb-2">Buyurtma raqami:</p>
            <h4 class="fw-bold text-dark mb-4">#@ViewBag.OrderNumber</h4>
            <p class="text-muted mb-4">
                Buyurtmangiz yaqin orada tayyorlanadi. Telefon raqamingizga xabar yuboriladi.
            </p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="/Cabinet/Orders" class="btn btn-success rounded-pill px-4">
                    <i class="bi bi-bag-check me-2"></i>Buyurtmalarimni ko'rish
                </a>
                <a href="/" class="btn btn-outline-success rounded-pill px-4">
                    <i class="bi bi-shop me-2"></i>Xarid davom ettirish
                </a>
            </div>
        </div>
    </div>
</div>
